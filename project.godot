[layer_names]

3d_physics/layer_1="walls_for_creatures"
3d_physics/layer_2="creatures"
3d_physics/layer_3="Layer 3"
3d_physics/layer_4="interactables"
3d_physics/layer_5="walls_for_projectiles"
