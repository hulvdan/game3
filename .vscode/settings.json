    //     "command": "node-sass ${file} ${fileDirname}/${fileBasenameNoExtension}.css",
    //     "runIn": "terminal"
    // },
    // {
    //     // Match any python files by language id.
    //     "languages": [
    //         "python"
    //     ],
    //     "command": "python.runLinting",
    //     "runIn": "vscode"
    // }
  ],
  "python.linting.enabled": false
}
