{
  "files.exclude": {
    "**/*.binpb": true,
    "**/*.translation": true,
    "**/*.tscn*.tmp": true,
    "**/*.uid": true,
    ".godot/": true,
    // ".venv/": true,
    "node_modules": true,
    "uv.lock": true
  },
  "search.exclude": {
    "**/*.binpb": true,
    "**/*.translation": true,
    "**/*.tscn*.tmp": true,
    "**/*.uid": true,
    "**/*_pb2.py": true,
    ".godot/": true,
    // ".venv/": true,
    "node_modules": true,
    "uv.lock": true
  },
  "files.associations": {
    "*.ldtk": "json",
    ".prettierrc": "json"
  },
  "runOnSave.commands": [
    {
      "match": ".json$",
      "command": "prettier -w ${file}"
    },
    {
      "match": ".(yml|yaml|yamlfmt|yamllint)$",
      "command": "yamlfmt ${file}"
    },
    {
      "match": "localization.csv$",
      "command": "uv run python cli/bf_cli.py godot_reimport_localization",
      "runningStatusMessage": "Localizing..."
    },
    {
      "match": "glib.yaml$",
      "command": "uv run python cli/bf_cli.py codegen windows debug",
      "runningStatusMessage": "glibbing..."
    },
    {
      "match": ".proto$",
      "command": "uv run cog -n utf-8 -U -r -P --markers=\"[[[cog cog]]] [[[end]]]\" ${file} && proto-renumber -replace ${file} && buf format -w ${file}"
    },
    {
      "match": "glib.proto$",
      "command": "uv run python cli/bf_cli.py codegen windows debug",
      "runningStatusMessage": "glibbing..."
    },
    {
      "match": ".gd$",
      "command": "uv run gdscript-formatter --reorder-code ${file}"
    },
    {
      "match": ".pyi?$",
      "command": "uv run cog -n utf-8 -U -r -P --markers=\"[[[cog cog]]] [[[end]]]\" ${file} && uv run ruff format ${file} && uv run ruff check --select I ${file} --fix"
    },
    {
      "match": "bf_lib.py$",
      "command": "testing.runCurrentFile",
      "runIn": "vscode"
    },
    {
      "match": ".md$",
      "command": "uv run cog -n utf-8 -U -r -P --markers=\"[[[cog cog]]] [[[end]]]\" ${file}"
    }
    // {
    //     // Match scss files except names start with `_`.
    //     "match": ".*\\.scss$",
    //     "notMatch": "[\\\\\\/]_[^\\\\\\/]*\\.scss$",
    //     "command": "node-sass ${file} ${fileDirname}/${fileBasenameNoExtension}.css",
    //     "runningStatusMessage": "Compiling ${fileBasename}",
    //     "finishStatusMessage": "${fileBasename} compiled"
    // },
    // {
    //     // Match less files except names start with `_`.
    //     "globMatch": "**/[^_]*.less",
    //     "command": "node-sass ${file} ${fileDirname}/${fileBasenameNoExtension}.css",
    //     "runIn": "terminal"
    // },
    // {
    //     // Match any python files by language id.
    //     "languages": [
    //         "python"
    //     ],
    //     "command": "python.runLinting",
    //     "runIn": "vscode"
    // }
  ],
  "python.testing.pytestArgs": [
    "cli"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "launches": {
    "run_f4": "tool_attacks_markuper"
  }
}
