{
  "files.exclude": {
    "**/*.tscn*.tmp": true,
    "**/*.binpb": true,
    ".godot/": true,
    ".venv/": true,
    "**/*.uid": true
  },
  "files.associations": {
    "*.ldtk": "json",
    ".prettierrc": "json"
  },
  "runOnSave.commands": [
    {
      "match": ".(yml|yaml|yamlfmt)$",
      "command": "yamlfmt ${file}",
      "runIn": "backend"
    },
    {
      "match": "localization.csv$",
      "command": "uv run python cli/bf_cli.py godot_reimport_localization",
      "runIn": "backend",
      "runningStatusMessage": "Localizing..."
    },
    {
      "match": "glib.yaml$",
      "command": "uv run python cli/bf_cli.py codegen windows debug",
      "runIn": "backend",
      "runningStatusMessage": "glibbing..."
    },
    {
      "match": ".proto$",
      "command": "proto-renumber -replace ${file} && buf format -w ${file}",
      "runIn": "backend"
    },
    {
      "match": "glib.proto$",
      "command": "uv run python cli/bf_cli.py codegen windows debug",
      "runIn": "backend",
      "runningStatusMessage": "glibbing..."
    },
    // {
    //   "match": ".gd$",
    //   "command": "uv run gdscript-formatter ${file}",
    //   "runIn": "backend"
    // },
    {
      "match": ".py$",
      "command": "uv run ruff check --select I ${file} --fix",
      "runIn": "backend"
    }
    // {
    //     // Match scss files except names start with `_`.
