      "command": "uv run python -m cli/bf_cli.py test",
      "icon": {
        "id": "run"
      }
    },
    {
      "label": "1_gitf",
      "type": "shell",
      "command": "uv run python -m cli/bf_cli.py gitf",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "3_itch",
      "type": "shell",
      "command": "uv run python -m cli/bf_cli.py deploy_itch",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "4_profiles",
      "type": "shell",
      "command": "uv run python -m cli/bf_cli.py profiles",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "5_types",
      "type": "shell",
      // "command": "pyright",
      // "args": [
      //   "cli"
      // ],
      "command": "ty",
      "args": [
        "check",
        "cli",
        "--output-format=concise",
        "--no-progress"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "run"
      },
      "presentation": {
        "revealProblems": "onProblem",
        "reveal": "never"
      },
      "problemMatcher": {
        "owner": "python",
        // "fileLocation": [
        //   "absolute"
        // ],
        "pattern": [
          {
            // "regexp": "^(.*\\.py):(\\d+):(\\d+) - (.*)$",
            "regexp": "^(.*\\.py):(\\d+):(\\d+): (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    }
  ]
}
