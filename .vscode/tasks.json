{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "2_test",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py test",
      "icon": {
        "id": "run"
      }
    },
    {
      "label": "1_gitf",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py gitf",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "3_itch",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py deploy_itch",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "4_profiles",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py profiles",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "5_mypy",
      "type": "shell",
      "command": "pyright",
      "args": [
        "cli"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "run"
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "python",
        "fileLocation": [
          "absolute"
        ],
        "pattern": [
          {
            "regexp": "^(.*\\.py):(\\d+):(\\d+) - (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    }
  ]
}
