{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "2_test",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py test",
      "icon": {
        "id": "run"
      }
    },
    {
      "label": "1_gitf",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py gitf",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "3_itch",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py deploy_itch",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "4_profiles",
      "type": "shell",
      "command": "uv run python cli/bf_cli.py profiles",
      "icon": {
        "id": "run"
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "5_lint",
      "type": "shell",
      "dependsOn": [
        "ty",
        "ruff"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "run"
      }
    },
    {
      "label": "ty",
      "type": "shell",
      "command": "ty",
      "args": [
        "check",
        "cli",
        "--output-format=concise",
        "--no-progress"
      ],
      "presentation": {
        "revealProblems": "onProblem",
        "reveal": "never"
      },
      "hide": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": [
          {
            "regexp": "^(.*\\.py):(\\d+):(\\d+): (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    },
    {
      "label": "ruff",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "ruff",
        "check",
        "cli",
        "--output-format=concise"
      ],
      "hide": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": [
          {
            "regexp": "^(.*\\.py):(\\d+):(\\d+): (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    }
  ]
}
